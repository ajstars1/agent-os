{
  "name": "@agent-os-core/cli",
  "version": "0.1.3",
  "description": "Terminal REPL adapter for agent-os — the `aos` CLI.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aos": "./dist/index.js",
    "aos-ask": "./dist/ask.js",
    "aos-status": "./dist/status.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agent-os-core/core": "0.1.3",
    "@agent-os-core/shared": "0.1.3",
    "@types/react": "^19.2.14",
    "chalk": "^5.4.1",
    "dotenv": "^16.4.0",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  }
}
