{
  "name": "agent-os",
  "version": "0.2.1",
  "description": "Self-hosted AI agent with persistent memory — CLI, Discord, and web API",
  "bin": {
    "aos": "./packages/cli/dist/index.js"
  },
  "files": [
    "packages/cli/dist",
    "packages/core/dist",
    "packages/shared/dist"
  ],
  "private": false,
  "packageManager": "npm@10.9.2",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "turbo run build",
    "cli": "node packages/cli/dist/index.js",
    "dev:cli": "turbo run dev --filter=@agent-os-core/cli",
    "dev:discord": "turbo run dev --filter=@agent-os-core/discord",
    "dev:web": "turbo run dev --filter=@agent-os-core/web",
    "dev:ui": "turbo run dev --filter=@agent-os-core/ui",
    "dev:engine": "cd packages/engine && poetry run python main.py",
    "engine:install": "cd packages/engine && poetry install",
    "engine:test": "cd packages/engine && poetry run pytest",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "benchmark": "npx tsx scripts/benchmark.ts",
    "seed-memory": "npx tsx scripts/seed-memory.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@types/node": "^22.0.0"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "next": "15.0.0"
  },
  "resolutions": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "next": "15.0.0"
  }
}
