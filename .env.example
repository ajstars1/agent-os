# AgentOS configuration — copy to ~/.agent-os/.env
# At least one of ANTHROPIC_API_KEY or GOOGLE_API_KEY is required.

# ── LLM providers ─────────────────────────────────────────────────────────────

# Claude (Anthropic) — default model for reasoning tasks
ANTHROPIC_API_KEY=

# Gemini (Google) — enables: dual-LLM routing, HAM compression, L4 self-learning
# Without this key, HAM compression falls back to plain-text storage
GOOGLE_API_KEY=

# ── Routing ───────────────────────────────────────────────────────────────────

# Default LLM: claude | gemini | auto
# auto = Gemini Flash classifies each message; routes to Claude for reasoning,
#        Gemini for large-context tasks
DEFAULT_MODEL=claude

# ── Storage ───────────────────────────────────────────────────────────────────

# Path to the SQLite memory database (WAL mode)
DB_PATH=~/.agent-os/memory.db

# ── Skills ────────────────────────────────────────────────────────────────────

# Directory of .md skill files — loaded and hot-reloaded as system context
SKILLS_DIR=~/.claude/skills

# Optional: path to a CLAUDE.md / system instructions file
CLAUDE_MD_PATH=./CLAUDE.md

# ── Agent profiles ────────────────────────────────────────────────────────────

# Directory of .json agent profile files — listed with /agents, loaded with --agent
AGENTS_DIR=~/.agent-os/agents

# ── Web API ───────────────────────────────────────────────────────────────────

# Port for the Hono web API server (node packages/web/dist/index.js)
WEB_PORT=3000

# CORS allowed origin for the web API
WEB_CORS_ORIGIN=*

# ── Config web UI ─────────────────────────────────────────────────────────────

# Port for /config web — browser-based config editor with SSE real-time sync
CONFIG_UI_PORT=7877

# ── File tool access ──────────────────────────────────────────────────────────

# Colon-separated list of directories the file tools (read_file, write_file)
# are allowed to access. Empty = cwd only.
ALLOWED_DIRS=

# ── Sleep cycle engine ────────────────────────────────────────────────────────

# URL of the Python neural engine backend (optional — enhances /dream consolidation)
# NEURAL_ENGINE_URL=http://localhost:8001
NEURAL_ENGINE_URL=

# ── Discord ───────────────────────────────────────────────────────────────────

# Required only if running the Discord bot adapter
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_CHANNELS=

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Node environment: development | production | test
NODE_ENV=production
