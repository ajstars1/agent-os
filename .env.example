# Required
ANTHROPIC_API_KEY=sk-ant-...

# Gemini fallback (optional — if absent, always use Claude)
GOOGLE_API_KEY=AIza...

# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_CHANNELS=

# Storage
DB_PATH=~/.agent-os/memory.db

# Skills (loaded as system context)
SKILLS_DIR=~/.claude/skills
CLAUDE_MD_PATH=./CLAUDE.md

# LLM routing: claude (default) | gemini | auto
# auto = Claude by default, routes to Gemini only for large-context/token-heavy tasks
DEFAULT_MODEL=claude

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Web server (packages/web)
WEB_PORT=3000
WEB_CORS_ORIGIN=*

# Named agents directory
AGENTS_DIR=~/.agent-os/agents

# Colon-separated list of dirs builtin file tools can access (empty = unrestricted)
ALLOWED_DIRS=
