[4.555144, "o", "\r\n"]
[4.555303, "o", "\u001b[1m  AgentOS\u001b[0m\u001b[2m  ·  type /help for commands\u001b[0m\r\n\u001b[2m  ─────────────────────────────────\r\n\u001b[0m\r\n"]
[4.556036, "o", "\u001b[1G"]
[4.55615, "o", "\u001b[0J\u001b[36m❯\u001b[0m \u001b[3G"]
[6.478436, "o", "/"]
